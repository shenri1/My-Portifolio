<section id="hero">
    <div id="tsparticles" class="hero-particles"></div>
    <div class="hero-inner">
        <div class="hero-avatar-wrap">
            <div class="hero-avatar-ring">
                <img
                    src="/1772192364889.jpg"
                    alt="Silas Cerqueira"
                    referrerpolicy="no-referrer"
                />
            </div>
            <div class="status-dot"></div>
        </div>

        <div class="hero-text">
            <div class="hero-status">
                <span class="slash">//</span>
                <span>Active System</span>
            </div>
            <h1 class="hero-name">
                Silas <br /><span class="hl">Cerqueira</span>
            </h1>

            <div class="terminal">
                <div class="terminal-bar">
                    <span class="dot red"></span>
                    <span class="dot yellow"></span>
                    <span class="dot green"></span>
                    <span class="terminal-path">silas@portfolio:~</span>
                </div>
                <div class="terminal-body">
                    <span class="prompt">$</span>
                    <span id="typedRole">Computer Engineering Student</span>
                </div>
            </div>

            <p class="hero-sub">
                Computer Engineering student focused on creating scalable
                software solutions and high-performance digital experiences.
            </p>
        </div>
    </div>
    <div class="hero-glow"></div>
</section>

<script>
    const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    ).matches;

    const roleEl = document.getElementById("typedRole");
    if (roleEl && !prefersReducedMotion) {
        const { default: Typed } = await import("typed.js");
        roleEl.textContent = "";
        new Typed(roleEl, {
            strings: [
                "Computer Engineering Student",
                "Backend Developer",
                "Data-Driven Builder",
            ],
            typeSpeed: 45,
            backSpeed: 25,
            backDelay: 1800,
            loop: true,
        });
    }

    const particlesEl = document.getElementById("tsparticles");
    if (particlesEl && !prefersReducedMotion) {
        const [{ tsParticles }, { loadSlim }] = await Promise.all([
            import("@tsparticles/engine"),
            import("@tsparticles/slim"),
        ]);
        await loadSlim(tsParticles);

        const accent = getComputedStyle(document.documentElement)
            .getPropertyValue("--accent")
            .trim();
        const particleCount = window.innerWidth < 640 ? 25 : 55;

        await tsParticles.load({
            id: "tsparticles",
            options: {
                fullScreen: { enable: false },
                background: { color: "transparent" },
                fpsLimit: 60,
                particles: {
                    number: { value: particleCount },
                    color: { value: accent },
                    links: {
                        enable: true,
                        color: accent,
                        distance: 130,
                        opacity: 0.25,
                        width: 1,
                    },
                    move: {
                        enable: true,
                        speed: 0.6,
                        outModes: { default: "out" },
                    },
                    opacity: { value: 0.4 },
                    size: { value: { min: 1, max: 2.5 } },
                },
                interactivity: {
                    events: { onHover: { enable: true, mode: "grab" } },
                    modes: { grab: { distance: 140, links: { opacity: 0.4 } } },
                },
            },
        });
    }
</script>

